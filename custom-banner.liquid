<section class="custom-banner">
 <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
    </section>

    <style>
.custom-banner {
  background-color: {{ section.settings.bg_color }};
  padding:20px;
  display:flex;
  justify-content:center;
  flex-direction: column;
  align-items: center;
  color:white;
}
</style>

    {% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Free Shipping over 999+"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Place your order now"
    },
    {
  "type": "color",
  "id": "bg_color",
  "label": "Background Color",
  "default": "#0000FF"
}
  ],
   "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}
